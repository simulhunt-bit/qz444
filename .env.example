# Copy this file to .env.local and fill in your real values.
# Never commit .env.local to git, and never paste keys into chat/docs/screenshots.

# Powers the /tools page (Ad Copy + SEO Meta generators).
# Get a fresh key at https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Optional shared-password gate for /tools and /api/generate.
# Leave blank to keep the tools page fully public.
ACCESS_PIN=
